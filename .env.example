# Servidor
# Porta em que a aplicação irá rodar
PORT=8000

# Host para bind do servidor
HOST=0.0.0.0

# Modo debug (true para desenvolvimento, false para produção)
DEBUG=true

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Banco de Dados
# URL de conexão do banco de dados (SQLite local por padrão)
DATABASE_URL=sqlite:///./toninho.db

# Redis (Message Broker e Cache)
# Host do Redis
REDIS_HOST=localhost

# Porta do Redis
REDIS_PORT=6379

# Database Redis (0-15)
REDIS_DB=0

# URL completa do broker Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# Backend de resultados do Celery
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Workers
# Número máximo de processos que podem ser executados simultaneamente
MAX_CONCURRENT_PROCESSES=5

# Concorrência dos workers Celery (número de threads/processos por worker)
WORKER_CONCURRENCY=2

# Extração
# Timeout padrão para extração (em segundos)
DEFAULT_TIMEOUT=3600

# Número máximo de tentativas em caso de falha
MAX_RETRIES=3

# Tamanho máximo por extração (em bytes, padrão: 1GB)
MAX_SIZE_PER_EXTRACTION=1073741824

# Diretório onde os arquivos extraídos serão salvos
OUTPUT_DIR=./output

# Cache
# Habilitar cache de requisições HTTP
CACHE_HTTP_REQUESTS=true

# Expiração do cache (em segundos)
CACHE_EXPIRATION=3600

# Processamento
# Número de threads para processamento paralelo
PARALLEL_THREADS=4

# Storage
# Tipo de storage (local, s3, gcs)
STORAGE_TYPE=local

# Segurança
# Chave secreta para tokens e assinaturas (MUDAR EM PRODUÇÃO!)
SECRET_KEY=change-me-in-production-please-use-strong-random-key
